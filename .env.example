# Copy to `.env` and fill in. `.env` is gitignored; this file is not.

# Backend origin WITHOUT a trailing slash and WITHOUT the /api/v1 prefix —
# src/lib/api.ts appends it. multi-tanent-backend runs on 3001 by default.
VITE_API_BASE_URL=http://localhost:3001

# Perimeter Basic Auth: base64("USERNAME:PASSWORD:CLIENT_MARKER"), sent on
# EVERY request including the /crypto/public-key bootstrap.
#
# Leave blank in local dev: the backend's BasicAuthMiddleware is a no-op
# unless NODE_ENV=production or BASIC_AUTH_FORCE=1. Fill this in for any
# deployed environment, matching BASIC_AUTH_USERNAME / BASIC_AUTH_PASSWORD /
# BASIC_AUTH_CLIENT_MARKER in the backend's .env.
VITE_API_BASIC_AUTH=

# Optional plaintext fallbacks, used only when VITE_API_BASIC_AUTH is unset.
# src/lib/basicAuth.ts assembles and base64-encodes them for you.
# VITE_API_BASIC_AUTH_USER=
# VITE_API_BASIC_AUTH_PASS=
# VITE_API_BASIC_AUTH_MARKER=
